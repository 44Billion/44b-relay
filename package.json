{
  "name": "social-relay",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "NODE_ENV=development node index.js",
    "job:status": "node bin/job/status.js",
    "job:reconcile-used-bytes": "node bin/job/reconcile-used-bytes.js",
    "job:migrate-irfs-v2": "node bin/job/migrate-irfs-v2.js",
    "job:migrate-hashtag-stats-keys": "node bin/job/migrate-hashtag-stats-keys.js",
    "job:delete-old-bundle-events": "node bin/job/delete-old-bundle-events.js",
    "job:reset-hashtag-stats-relations": "node bin/job/reset-hashtag-stats-relations.js",
    "job:reset-event-topics": "node bin/job/reset-event-topics.js",
    "// test": "--test-concurrency=1 to benefit from single MeiliSearch instance setup at global-setup.js without conflicts between parallel tests",
    "test": "NODE_ENV=test node --test --test-concurrency=1 --test-global-setup=tests/global-setup.js --experimental-test-module-mocks 'tests/**/*.test.js'",
    "test:only": "NODE_ENV=test node --test --test-only --test-concurrency=1 --test-global-setup=tests/global-setup.js --experimental-test-module-mocks 'tests/**/*.test.js'",
    "test:integration": "bash tests/integration/run-suite.sh",
    "build:wordninja": "node lib/wordninja/build-dictionaries.js",
    "// download:mediapipe-model": "Kept for reference because `npm install @mediapipe/tasks-text` lib is currently web-only. Used @huggingface/transformers for now.",
    "download:mediapipe-model": "node lib/mediapipe/download-model.js"
  },
  "engines": {
    "node": "24.8.0"
  },
  "imports": {
    "#config/*": "./config/*",
    "#constants/*": "./constants/*",
    "#helpers/*": "./helpers/*",
    "#lib/*": "./lib/*",
    "#models/*": "./models/*",
    "#services/*": "./services/*"
  },
  "dependencies": {
    "@huggingface/transformers": "^3.4.0",
    "@noble/curves": "^2.0.1",
    "@noble/hashes": "^2.0.1",
    "deta": "^1.1.0",
    "dotenv": "^16.0.3",
    "fast-bloom-filter": "^2.1.1",
    "franc": "^6.2.0",
    "iso-639-3": "^3.0.1",
    "lande": "^1.0.10",
    "libp2r2p": "^0.9.0",
    "meilisearch": "^0.55.0",
    "nmmr": "^2.0.0",
    "nostr-hll": "^1.0.0",
    "sharp": "^0.33.5",
    "sketch-oxide-node": "^0.1.6",
    "snowball-stemmers": "^0.6.0",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "eslint": "^9.39.2",
    "globals": "^17.0.0",
    "neostandard": "^0.12.2",
    "testcontainers": "^11.12.0"
  }
}
